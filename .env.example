# ============================================================
#  QualityDoc — Variables de entorno
#  Copia este archivo como ".env" y cambia los valores.
#  NUNCA subas el archivo ".env" real al repositorio.
# ============================================================

# Entorno
ASPNETCORE_ENVIRONMENT=Development

# ── SQL Server (nucleo) ─────────────────────────────────────
SQL_SA_PASSWORD=QualityDoc@2026!
SQL_DB=QualityDocDB

# ── PostgreSQL (auditoria) ──────────────────────────────────
PG_USER=qd_admin
PG_PASSWORD=qd_pg_2026!
PG_DB=qualitydoc_audit

# ── MongoDB (metadatos) ─────────────────────────────────────
MONGO_USER=qd_root
MONGO_PASSWORD=qd_mongo_2026!
MONGO_DB=qualitydoc_meta

# ── Microservicio Node (API key compartida con .NET) ───────
NODE_API_KEY=node-internal-key-2026

# ── Portal PHP: empresa que muestra (2 = empresa-demo) ──────
PORTAL_EMPRESA_ID=2

# ── Nginx gateway (URL pública de los archivos vía /files) ──
NGINX_FILES_URL=http://localhost:8080/files

# ── Seed (contrasena de los usuarios de prueba) ─────────────
SEED_PASSWORD=QualityDoc2026!
