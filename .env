# Variables reales (no se sube al repo). Coinciden con appsettings.Development.json.
ASPNETCORE_ENVIRONMENT=Development

# SQL Server (nucleo)
SQL_SA_PASSWORD=QualityDoc@2026!
SQL_DB=QualityDocDB

# PostgreSQL (auditoria)
PG_USER=qd_admin
PG_PASSWORD=qd_pg_2026!
PG_DB=qualitydoc_audit

# MongoDB (metadatos)
MONGO_USER=qd_root
MONGO_PASSWORD=qd_mongo_2026!
